# ------------------------------------------------------------------
# Anvil website — environment variables
# ------------------------------------------------------------------
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
# `.env` is git-ignored; this template is the committed source of truth.
#
# This site is offline-first and calls no private APIs, so there are
# NO secrets here — every value below is a public URL.
# ------------------------------------------------------------------

# Canonical production URL of the site. Used to build every absolute URL
# on SEO surfaces: canonical tags, og:image, sitemap, robots, JSON-LD
# (see lib/site.ts). Must be a domain that actually serves the site — a
# wrong value silently breaks social share covers.
#
# Leave BLANK for local dev (localhost works without it). Set it for any
# deployment that isn't on Vercel's auto-detected domain.
NEXT_PUBLIC_SITE_URL=https://anvil-website.vercel.app

# GitHub repos the site links to, as "owner/name" slugs. Everything is
# derived from these — override them to point a fork at your own repos:
#
#   NEXT_PUBLIC_ANVIL_REPO    -> source repo. Drives every "GitHub" link:
#                                repo, issues, discussions, contributing,
#                                license, etc. (lib/site.ts + lib/releases.ts)
#
#   NEXT_PUBLIC_RELEASES_REPO -> the DOWNLOAD repo. Drives the build links:
#                                * latest build  -> fetched from this repo's
#                                  GitHub API "releases/latest" (lib/releases.ts)
#                                * previous builds -> this repo's /releases page
#
# If unset, both fall back to the canonical Anvil repos in code, so the site
# still builds. Values are public — no token is needed to read releases.
NEXT_PUBLIC_ANVIL_REPO=kudzaiprichard/anvil
NEXT_PUBLIC_RELEASES_REPO=kudzaiprichard/anvil-releases

# ------------------------------------------------------------------
# Injected automatically by Vercel — DO NOT set these yourself.
# Listed here only so you know the URL-resolution order in lib/site.ts:
#   NEXT_PUBLIC_SITE_URL  ->  VERCEL_PROJECT_PRODUCTION_URL  ->  VERCEL_URL
#   VERCEL_PROJECT_PRODUCTION_URL   # your project's production domain
#   VERCEL_URL                      # the per-deployment preview domain
# ------------------------------------------------------------------
